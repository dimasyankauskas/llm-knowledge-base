# LLM Knowledge Base — Environment Configuration
# Copy this file to .env and fill in your values

# ── LLM Provider ──────────────────────────────────────────────────────────────
# The wiki works with Ollama (local), Anthropic, or any OpenAI-compatible API.
# Uncomment the section for your provider.

# ── Option A: Ollama (local, recommended for privacy/speed) ────────────────────
# Download at https://ollama.com
# Most models work well — qwen3.5:agentic, llama3.1, mistral, etc.
export OLLAMA_BASE_URL=http://localhost:11434
export OLLAMA_MODEL=qwen3.5:agentic
# export OLLAMA_API_KEY=ollama  # not required for local Ollama

# ── Option B: Anthropic Claude (cloud) ───────────────────────────────────────
# Get your key at https://console.anthropic.com/
# export ANTHROPIC_API_KEY=sk-ant-...

# ── Option C: OpenAI-compatible API ─────────────────────────────────────────
# For LM Studio, Groq, Perplexity, or any OpenAI-compatible endpoint
# export OLLAMA_BASE_URL=https://api.groq.com/openai/v1
# export OLLAMA_MODEL=llama-3.1-70b-versatile
# export OLLAMA_API_KEY=gsk_...

# ── Option D: OpenAI direct ───────────────────────────────────────────────────
# export ANTHROPIC_BASE_URL=https://api.openai.com/v1
# export OLLAMA_MODEL=gpt-4o
# export OLLAMA_API_KEY=sk-...
